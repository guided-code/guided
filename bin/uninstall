#!/bin/sh

set -eu

install_location=$HOME/guided
repo_location=git@github.com:guided-code/guided.git

cleanup() {
  cd - > /dev/null
}

ensure_uv() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "[.]Error: uv is not installed. Please install uv first."
    exit 1
  fi
}

uninstall() {
  echo "[.]Uninstalling Guided..."
  cd $install_location
  uv tool uninstall guided
}

# Show instructions
show_instructions() {
  echo ""
  echo "[.]Instructions..."
  echo "You can safely remove $install_location"
}

# Prep
DIR="$( cd "$( dirname "$0" )" >/dev/null 2>&1 && pwd )"
cd $DIR/..
trap cleanup SIGINT EXIT

# Start
ensure_uv
uninstall
show_instructions
