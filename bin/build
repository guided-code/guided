#!/bin/sh

set -eu

cwd="$( cd "$( dirname "$0" )" >/dev/null 2>&1 && pwd )"

cleanup() {
  cd $cwd > /dev/null
}

ensure_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "[.]Error: docker is not installed. Please install docker first."
    exit 1
  fi
}

run_task() {
  echo "[.]Running task..."
  docker buildx build --platform linux/amd64,linux/arm64 --tag guided:latest --load .
}

# Prep
trap cleanup INT EXIT

# Start
ensure_docker
run_task
