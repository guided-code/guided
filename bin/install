#!/bin/sh

set -euo pipefail

install_location=$HOME/guided
repo_location=git@github.com:guided-code/guided.git

cleanup() {
  cd - > /dev/null
}

ensure_uv() {
  if [ ! command -v uv &> /dev/null ]; then
    echo "[.]Error: uv is not installed. Please install uv first."
    exit 1
  fi
}

# Checkout or update git repository
download() {
  if [ -d "$install_location" ]; then
    echo "[.]Updating Guided at $install_location..."
    git -C "$install_location" pull
  else
    echo "[.]Downloading Guided..."
    git clone $repo_location $install_location
  fi
}

# Build the Python executable
build() {
  echo "[.]Building Guided..."
  uv build
}

# Add
install() {
  echo "[.]Installing Guided..."
  uv tool install --editable .
}

# Show instructions
show_instructions() {
  echo ""
  echo "[.]Instructions..."
  echo "Guided has been installed to $install_location"
  echo ""
  echo "You can now use guide commands."
}

# Prep
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
cd $DIR/..
trap cleanup SIGINT EXIT

# Start
ensure_uv
download
build
install
show_instructions
