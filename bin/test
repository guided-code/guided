#!/bin/sh

set -eu

cwd="$( cd "$( dirname "$0" )" >/dev/null 2>&1 && pwd )"

cleanup() {
  cd $cwd > /dev/null
}

ensure_uv() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "[.]Error: uv is not installed. Please install uv first."
    exit 1
  fi
}

run_task() {
  echo "[.]Running task..."
  uv run pytest $@
}

# Prep
trap cleanup INT EXIT

# Start
ensure_uv
run_task $@
